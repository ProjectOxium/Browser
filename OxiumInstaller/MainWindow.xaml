<Window x:Class="OxiumInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:OxiumInstaller.Views"
        WindowStyle="None"
        ResizeMode="CanResize"
        Width="680" Height="520"
        MinWidth="600" MinHeight="440"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/icon.ico">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0"
                      CaptionHeight="0"
                      ResizeBorderThickness="6"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border Background="{StaticResource OxiumBlackBrush}"
            BorderBrush="{StaticResource OxiumRedBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="54"/>
            </Grid.RowDefinitions>

            <!-- ═══ Title Bar ═══════════════════════════════════ -->
            <Border Grid.Row="0"
                    Background="{StaticResource OxiumSurfaceBrush}"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <!-- Logo: stylized OXIUM "O" icon -->
                        <Viewbox Width="20" Height="20" Margin="0,0,10,0">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="{StaticResource OxiumRedBrush}"
                                      StrokeThickness="2"
                                      Fill="Transparent"
                                      Data="M 12,2 A 10,10 0 1,1 2,12 A 10,10 0 1,1 12,2 Z
                                            M 12,7 A 5,5 0 1,0 7,12 A 5,5 0 1,0 12,7 Z"
                                      Effect="{StaticResource NeonGlowSubtle}"/>
                                <Line X1="12" Y1="3" X2="12" Y2="21"
                                      Stroke="{StaticResource OxiumRedBrush}"
                                      StrokeThickness="1" Opacity="0.4"/>
                                <Line X1="3" Y1="12" X2="21" Y2="12"
                                      Stroke="{StaticResource OxiumRedBrush}"
                                      StrokeThickness="1" Opacity="0.4"/>
                            </Canvas>
                        </Viewbox>

                        <TextBlock Text="OXIUM BROWSER INSTALLER"
                                   FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource OxiumRedBrush}"
                                   VerticalAlignment="Center"
                                   Effect="{StaticResource NeonGlowSubtle}"/>
                    </StackPanel>

                    <!-- Window control buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="_" Style="{StaticResource TitleBarButton}"
                                Click="MinimizeButton_Click"/>
                        <Button Content="&#x2715;" Style="{StaticResource TitleBarCloseButton}"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ Page Content Area ═══════════════════════════ -->
            <Grid Grid.Row="1" Margin="24,20,24,12">
                <views:WelcomePage Visibility="{Binding WelcomeVisibility}"/>
                <views:LicensePage Visibility="{Binding LicenseVisibility}"/>
                <views:PrerequisitesPage Visibility="{Binding PrerequisitesVisibility}"/>
                <views:InstallPathPage Visibility="{Binding InstallPathVisibility}"/>
                <views:ProgressPage Visibility="{Binding ProgressVisibility}"/>
                <views:CompletePage Visibility="{Binding CompleteVisibility}"/>
            </Grid>

            <!-- ═══ Navigation Bar ══════════════════════════════ -->
            <Border Grid.Row="2" Background="{StaticResource OxiumSurfaceBrush}">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="PROJECT OXIUM"
                               FontFamily="Consolas" FontSize="10"
                               Foreground="{StaticResource OxiumTextMutedBrush}"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="CANCEL"
                                Style="{StaticResource NeonButtonSecondary}"
                                Visibility="{Binding CancelButtonVisibility}"
                                Command="{Binding CancelCommand}"
                                Margin="0,0,8,0"/>
                        <Button Content="&#x276E; BACK"
                                Style="{StaticResource NeonButtonSecondary}"
                                Visibility="{Binding BackButtonVisibility}"
                                Command="{Binding BackCommand}"
                                Margin="0,0,8,0"/>
                        <Button Content="NEXT &#x276F;"
                                Style="{StaticResource NeonButton}"
                                Visibility="{Binding NextButtonVisibility}"
                                Command="{Binding NextCommand}"
                                IsEnabled="{Binding CanGoNext}"/>
                        <Button Content="INSTALL"
                                Style="{StaticResource NeonButton}"
                                Visibility="{Binding InstallButtonVisibility}"
                                Command="{Binding InstallCommand}"/>
                        <Button Content="FINISH"
                                Style="{StaticResource NeonButton}"
                                Visibility="{Binding FinishButtonVisibility}"
                                Command="{Binding FinishCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
