<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         OXIUM INSTALLER — NEON BLACK/RED THEME
         Project Oxium
         ============================================================ -->

    <!-- ── Color Palette ──────────────────────────────────────── -->
    <Color x:Key="OxiumBlack">#0A0A0C</Color>
    <Color x:Key="OxiumSurface">#111116</Color>
    <Color x:Key="OxiumSurfaceLight">#1A1A22</Color>
    <Color x:Key="OxiumSurfaceCard">#16161C</Color>
    <Color x:Key="OxiumRed">#E01020</Color>
    <Color x:Key="OxiumRedBright">#FF2040</Color>
    <Color x:Key="OxiumRedGlow">#FF0030</Color>
    <Color x:Key="OxiumRedDark">#6B0000</Color>
    <Color x:Key="OxiumRedMuted">#801020</Color>
    <Color x:Key="OxiumTextPrimary">#E8E8E8</Color>
    <Color x:Key="OxiumTextSecondary">#888888</Color>
    <Color x:Key="OxiumTextMuted">#555555</Color>
    <Color x:Key="OxiumSuccess">#00E040</Color>
    <Color x:Key="OxiumWarning">#FFAA00</Color>
    <Color x:Key="OxiumError">#FF1A2E</Color>
    <Color x:Key="OxiumBorder">#2A2A2A</Color>

    <!-- ── Solid Brushes ──────────────────────────────────────── -->
    <SolidColorBrush x:Key="OxiumBlackBrush" Color="{StaticResource OxiumBlack}"/>
    <SolidColorBrush x:Key="OxiumSurfaceBrush" Color="{StaticResource OxiumSurface}"/>
    <SolidColorBrush x:Key="OxiumSurfaceLightBrush" Color="{StaticResource OxiumSurfaceLight}"/>
    <SolidColorBrush x:Key="OxiumSurfaceCardBrush" Color="{StaticResource OxiumSurfaceCard}"/>
    <SolidColorBrush x:Key="OxiumRedBrush" Color="{StaticResource OxiumRed}"/>
    <SolidColorBrush x:Key="OxiumRedBrightBrush" Color="{StaticResource OxiumRedBright}"/>
    <SolidColorBrush x:Key="OxiumRedDarkBrush" Color="{StaticResource OxiumRedDark}"/>
    <SolidColorBrush x:Key="OxiumRedMutedBrush" Color="{StaticResource OxiumRedMuted}"/>
    <SolidColorBrush x:Key="OxiumTextPrimaryBrush" Color="{StaticResource OxiumTextPrimary}"/>
    <SolidColorBrush x:Key="OxiumTextSecondaryBrush" Color="{StaticResource OxiumTextSecondary}"/>
    <SolidColorBrush x:Key="OxiumTextMutedBrush" Color="{StaticResource OxiumTextMuted}"/>
    <SolidColorBrush x:Key="OxiumSuccessBrush" Color="{StaticResource OxiumSuccess}"/>
    <SolidColorBrush x:Key="OxiumWarningBrush" Color="{StaticResource OxiumWarning}"/>
    <SolidColorBrush x:Key="OxiumErrorBrush" Color="{StaticResource OxiumError}"/>
    <SolidColorBrush x:Key="OxiumBorderBrush" Color="{StaticResource OxiumBorder}"/>

    <!-- ── Neon Glow Effects ──────────────────────────────────── -->
    <DropShadowEffect x:Key="NeonGlow" Color="{StaticResource OxiumRedGlow}"
                      BlurRadius="20" ShadowDepth="0" RenderingBias="Quality"/>
    <DropShadowEffect x:Key="NeonGlowStrong" Color="{StaticResource OxiumRedGlow}"
                      BlurRadius="35" ShadowDepth="0" RenderingBias="Quality"/>
    <DropShadowEffect x:Key="NeonGlowSubtle" Color="{StaticResource OxiumRedGlow}"
                      BlurRadius="8" ShadowDepth="0" RenderingBias="Quality"/>
    <DropShadowEffect x:Key="NeonGlowGreen" Color="{StaticResource OxiumSuccess}"
                      BlurRadius="12" ShadowDepth="0" RenderingBias="Quality"/>

    <!-- ── Converters ─────────────────────────────────────────── -->
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <!-- ── Window Chrome Style ────────────────────────────────── -->
    <Style x:Key="NeonWindow" TargetType="Window">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="WindowStyle" Value="None"/>
        <Setter Property="AllowsTransparency" Value="True"/>
        <Setter Property="ResizeMode" Value="CanResize"/>
        <Setter Property="WindowStartupLocation" Value="CenterScreen"/>
    </Style>

    <!-- ── Title Bar Buttons ──────────────────────────────────── -->
    <Style x:Key="TitleBarButton" TargetType="Button">
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource OxiumTextSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource OxiumSurfaceLightBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource OxiumTextPrimaryBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource OxiumRedMutedBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="TitleBarCloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource OxiumRedBrush}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource OxiumRedDarkBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── Primary Neon Button ────────────────────────────────── -->
    <Style x:Key="NeonButton" TargetType="Button">
        <Setter Property="Background" Value="#1A0A0E"/>
        <Setter Property="Foreground" Value="{StaticResource OxiumRedBrightBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OxiumRedBrush}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="24,8"/>
        <Setter Property="MinWidth" Value="100"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Effect" Value="{StaticResource NeonGlowSubtle}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="2"
                            Effect="{TemplateBinding Effect}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2A1018"/>
                            <Setter Property="BorderBrush" Value="{StaticResource OxiumRedBrightBrush}"/>
                            <Setter Property="Effect" Value="{StaticResource NeonGlow}"/>
                            <Setter Property="Foreground" Value="#FF4466"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{StaticResource OxiumRedDarkBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource OxiumTextPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35"/>
                            <Setter Property="Effect" Value="{x:Null}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Secondary / Back Button ────────────────────────────── -->
    <Style x:Key="NeonButtonSecondary" TargetType="Button" BasedOn="{StaticResource NeonButton}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{StaticResource OxiumBorderBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource OxiumTextSecondaryBrush}"/>
        <Setter Property="Effect" Value="{x:Null}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource OxiumSurfaceLightBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource OxiumRedBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource OxiumTextPrimaryBrush}"/>
                <Setter Property="Effect" Value="{StaticResource NeonGlowSubtle}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource OxiumRedDarkBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── TextBox ────────────────────────────────────────────── -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource OxiumSurfaceCardBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource OxiumTextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OxiumBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="CaretBrush" Value="{StaticResource OxiumRedBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource OxiumRedMutedBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="2">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource OxiumRedBrush}"/>
                            <Setter Property="Effect" Value="{StaticResource NeonGlowSubtle}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── CheckBox ───────────────────────────────────────────── -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource OxiumTextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="checkBorder"
                                Width="18" Height="18"
                                Background="Transparent"
                                BorderBrush="{StaticResource OxiumBorderBrush}"
                                BorderThickness="1.5"
                                CornerRadius="1"
                                Margin="0,0,8,0">
                            <Path x:Name="checkMark"
                                  Data="M 3,9 L 7,13 L 15,4"
                                  Stroke="{StaticResource OxiumRedBrightBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Visibility="Collapsed"/>
                        </Border>
                        <ContentPresenter VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="checkBorder" Property="BorderBrush" Value="{StaticResource OxiumRedBrush}"/>
                            <Setter TargetName="checkBorder" Property="Effect" Value="{StaticResource NeonGlowSubtle}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="checkBorder" Property="BorderBrush" Value="{StaticResource OxiumRedMutedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── ProgressBar ────────────────────────────────────────── -->
    <Style TargetType="ProgressBar">
        <Setter Property="Height" Value="6"/>
        <Setter Property="Background" Value="{StaticResource OxiumSurfaceCardBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{TemplateBinding Background}" CornerRadius="3">
                        <Border x:Name="PART_Track">
                            <Border x:Name="PART_Indicator"
                                    Background="{StaticResource OxiumRedBrush}"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Effect="{StaticResource NeonGlowSubtle}"/>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── ScrollBar (dark) ───────────────────────────────────── -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid>
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="{StaticResource OxiumRedMutedBrush}"
                                                    CornerRadius="4"
                                                    Opacity="0.6"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── ScrollViewer ───────────────────────────────────────── -->
    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- ── Hyperlink-like Button (Browse) ─────────────────────── -->
    <Style x:Key="LinkButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource OxiumTextSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="Transparent"
                            BorderBrush="{StaticResource OxiumBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="1">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource OxiumRedBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource OxiumRedBrightBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Section Divider ────────────────────────────────────── -->
    <Style x:Key="NeonDivider" TargetType="Rectangle">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Fill" Value="{StaticResource OxiumRedMutedBrush}"/>
        <Setter Property="Effect" Value="{StaticResource NeonGlowSubtle}"/>
        <Setter Property="Margin" Value="0,8"/>
    </Style>

    <!-- ── Status Dot Template ────────────────────────────────── -->
    <Style x:Key="StatusDot" TargetType="Ellipse">
        <Setter Property="Width" Value="10"/>
        <Setter Property="Height" Value="10"/>
        <Setter Property="Margin" Value="0,0,10,0"/>
    </Style>

    <!-- ── Section Heading Text ───────────────────────────────── -->
    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource OxiumTextPrimaryBrush}"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <Style x:Key="SectionSubtitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource OxiumTextSecondaryBrush}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- ── Status Text ────────────────────────────────────────── -->
    <Style x:Key="StatusLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource OxiumTextSecondaryBrush}"/>
        <Setter Property="Margin" Value="0,2"/>
    </Style>

    <!-- ── Card Container ─────────────────────────────────────── -->
    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource OxiumSurfaceCardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OxiumBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="CornerRadius" Value="3"/>
    </Style>

</ResourceDictionary>
