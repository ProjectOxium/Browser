<UserControl x:Class="OxiumInstaller.Views.WelcomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">

            <!-- Oxium Logo Icon -->
            <Viewbox Width="100" Height="100" Margin="0,0,0,20">
                <Canvas Width="120" Height="120">
                    <!-- Outer ring -->
                    <Path Stroke="#FF2040" StrokeThickness="5" Fill="Transparent"
                          Data="M 60,8 A 52,52 0 1,1 8,60 A 52,52 0 1,1 60,8 Z"
                          Effect="{StaticResource NeonGlow}"/>
                    <!-- Center crosshair ring -->
                    <Path Stroke="#E01020" StrokeThickness="2" Fill="Transparent"
                          Data="M 60,28 A 32,32 0 1,1 28,60 A 32,32 0 1,1 60,28 Z"
                          Effect="{StaticResource NeonGlowSubtle}"/>
                    <!-- Cross lines -->
                    <Line X1="60" Y1="12" X2="60" Y2="108"
                          Stroke="#FF2040" StrokeThickness="2" Opacity="0.6"
                          Effect="{StaticResource NeonGlowSubtle}"/>
                    <Line X1="12" Y1="60" X2="108" Y2="60"
                          Stroke="#FF2040" StrokeThickness="2" Opacity="0.6"
                          Effect="{StaticResource NeonGlowSubtle}"/>
                    <!-- Diagonal accents -->
                    <Line X1="23" Y1="23" X2="35" Y2="35"
                          Stroke="#E01020" StrokeThickness="1.5" Opacity="0.4"/>
                    <Line X1="97" Y1="23" X2="85" Y2="35"
                          Stroke="#E01020" StrokeThickness="1.5" Opacity="0.4"/>
                    <Line X1="23" Y1="97" X2="35" Y2="85"
                          Stroke="#E01020" StrokeThickness="1.5" Opacity="0.4"/>
                    <Line X1="97" Y1="97" X2="85" Y2="85"
                          Stroke="#E01020" StrokeThickness="1.5" Opacity="0.4"/>
                    <!-- Center dot -->
                    <Ellipse Width="6" Height="6" Fill="#FF2040"
                             Canvas.Left="57" Canvas.Top="57"
                             Effect="{StaticResource NeonGlowSubtle}"/>
                </Canvas>
            </Viewbox>

            <!-- Branding -->
            <TextBlock Text="OXIUM"
                       FontFamily="Consolas" FontSize="48" FontWeight="Bold"
                       Foreground="{StaticResource OxiumRedBrush}"
                       HorizontalAlignment="Center"
                       Effect="{StaticResource NeonGlow}"/>

            <TextBlock Text="INSTALLER"
                       FontFamily="Consolas" FontSize="18" FontWeight="Light"
                       Foreground="{StaticResource OxiumTextPrimaryBrush}"
                       HorizontalAlignment="Center"
                        Margin="0,4,0,0"/>

            <Rectangle Style="{StaticResource NeonDivider}" Width="300" Margin="0,20"/>

            <TextBlock Text="{Binding VersionDisplay}"
                       Style="{StaticResource SectionSubtitle}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Text="by Project Oxium"
                   FontFamily="Consolas" FontSize="10"
                   Foreground="{StaticResource OxiumTextMutedBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,8"/>
    </Grid>
</UserControl>
