<UserControl x:Class="OxiumInstaller.Views.PrerequisitesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="SYSTEM CHECK"
                       Style="{StaticResource SectionTitle}"/>
            <TextBlock Text="Verifying your system meets the requirements..."
                       Style="{StaticResource SectionSubtitle}"/>
        </StackPanel>

        <ItemsControl Grid.Row="1"
                      ItemsSource="{Binding Prerequisites}"
                      Margin="0,16,0,0">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource OxiumSurfaceCardBrush}"
                            BorderBrush="{StaticResource OxiumBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="14,10"
                            Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid VerticalAlignment="Center" Margin="0,0,12,0">
                                <Ellipse Width="12" Height="12"
                                         Fill="{StaticResource OxiumSuccessBrush}"
                                         Effect="{StaticResource NeonGlowGreen}"
                                         Visibility="{Binding PassedVisibility}"/>
                                <Ellipse Width="12" Height="12"
                                         Fill="{StaticResource OxiumErrorBrush}"
                                         Effect="{StaticResource NeonGlowSubtle}"
                                         Visibility="{Binding FailedVisibility}"/>
                                <Ellipse Width="12" Height="12"
                                         Fill="{StaticResource OxiumWarningBrush}"
                                         Visibility="{Binding CheckingVisibility}"/>
                            </Grid>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Name}"
                                           FontFamily="Consolas" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource OxiumTextPrimaryBrush}"/>
                                <TextBlock Text="{Binding StatusMessage}"
                                           Style="{StaticResource StatusLabel}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
