<UserControl x:Class="OxiumInstaller.Views.ProgressPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid VerticalAlignment="Center">
        <StackPanel MaxWidth="440" HorizontalAlignment="Center">

            <TextBlock Text="INSTALLING"
                       Style="{StaticResource SectionTitle}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>

            <TextBlock Text="{Binding ProgressStatus}"
                       Style="{StaticResource StatusLabel}"
                       HorizontalAlignment="Center"
                       FontSize="13"
                       Margin="0,8,0,16"/>

            <ProgressBar Value="{Binding ProgressValue}"
                         Minimum="0" Maximum="100"
                         Height="8"
                         Margin="0,8"/>

            <TextBlock Text="{Binding ProgressPercentDisplay}"
                       FontFamily="Consolas" FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource OxiumRedBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,0"
                       Effect="{StaticResource NeonGlowSubtle}"/>

        </StackPanel>
    </Grid>
</UserControl>
