<UserControl x:Class="OxiumInstaller.Views.LicensePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="LICENSE AGREEMENT"
                   Style="{StaticResource SectionTitle}"/>

        <TextBlock Grid.Row="0"
                   Text="Please review the license terms before installing."
                   Style="{StaticResource SectionSubtitle}"
                   Margin="0,28,0,0"/>

        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="12" Margin="0,12,0,0">
            <TextBox Text="{Binding LicenseText, Mode=OneWay}"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Background="Transparent"
                     BorderThickness="0"
                     FontFamily="Consolas"
                     FontSize="12"
                     Foreground="{StaticResource OxiumTextSecondaryBrush}"/>
        </Border>

        <CheckBox Grid.Row="2"
                  IsChecked="{Binding IsLicenseAccepted}"
                  Content="I accept the terms of the license agreement"
                  Margin="0,12,0,0"/>
    </Grid>
</UserControl>
