<UserControl x:Class="OxiumInstaller.Views.CompletePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid VerticalAlignment="Center">
        <StackPanel MaxWidth="400" HorizontalAlignment="Center">

            <!-- Green checkmark -->
            <Viewbox Width="64" Height="64" Margin="0,0,0,20">
                <Canvas Width="64" Height="64">
                    <Ellipse Width="64" Height="64"
                             Stroke="{StaticResource OxiumSuccessBrush}"
                             StrokeThickness="3" Fill="Transparent"
                             Effect="{StaticResource NeonGlowGreen}"/>
                    <Path Data="M 18,32 L 28,44 L 46,22"
                          Stroke="{StaticResource OxiumSuccessBrush}"
                          StrokeThickness="4"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Fill="Transparent"
                          Effect="{StaticResource NeonGlowGreen}"/>
                </Canvas>
            </Viewbox>

            <TextBlock Text="INSTALLATION COMPLETE"
                       Style="{StaticResource SectionTitle}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>

            <TextBlock Text="Oxium has been successfully installed on your system."
                       Style="{StaticResource SectionSubtitle}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,8,0,0"/>

            <Rectangle Style="{StaticResource NeonDivider}" Width="200" Margin="0,24"/>

            <CheckBox IsChecked="{Binding LaunchOnExit}"
                      Content="Launch Oxium when the installer exits"
                      HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
